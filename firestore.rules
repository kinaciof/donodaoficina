rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permite que o usuário acesse o próprio perfil na coleção users
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Regra multi-tenant: Restringe o acesso aos dados da oficina apenas ao respectivo dono
    // Todas as subcoleções (clientes, ordens, peças) devem ficar dentro do tenant.
    match /tenants/{tenantId} {
      // Permite ler/escrever no documento da própria oficina
      allow read, write: if request.auth != null && request.auth.uid == tenantId;
      
      // Permite ler/escrever em qualquer documento filho (subcoleções) da oficina
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == tenantId;
      }
    }
  }
}
